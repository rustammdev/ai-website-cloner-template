# --- Runtime ---
# "development" | "test" | "production". In production the server refuses to
# boot unless ALLOWED_ORIGINS is set explicitly.
NODE_ENV=development
PORT=3001

# --- LLM Providers ---
# OPENAI and DEEPSEEK share the OpenAI SDK (DeepSeek is OpenAI-compatible).
# ANTHROPIC and GOOGLE need their own SDKs installed — see optionalDependencies.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# --- LLM Defaults ---
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# --- CORS ---
# Comma-separated list of origins allowed to send credentialed requests.
# With credentials: true the spec forbids wildcards, so we echo the incoming
# Origin header back only if it appears in this list.
#
# The Chrome extension connects to the SSE bridge (`/bridge/subscribe`) and
# POSTs RPC responses (`/bridge/respond`) using `credentials: "include"`, so
# its origin MUST be on this list in any environment that checks CORS.
# Find the extension ID at chrome://extensions with Developer mode enabled —
# it is a 32-character lowercase token, e.g. "abcdefghijklmnopqrstuvwxyzabcdef".
#
# Typical dev setup:
#   ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://<your-extension-id>
# Typical prod setup (REQUIRED when NODE_ENV=production):
#   ALLOWED_ORIGINS=https://clone.example.com,chrome-extension://<prod-extension-id>
ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://<your-extension-id>

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/ai_cloner
MONGODB_DB_NAME=ai_cloner

# --- Upload storage ---
# Screenshots and thumbnails for saved generations. Local disk for dev; swap
# for S3/R2/Supabase by replacing src/storage/local.ts.
STORAGE_DIR=./storage

# --- Agent graph ---
# Primary safety net: max model → tool round-trips per chat turn. Hits the
# brake cleanly (agent returns its last message) when reached — no exception.
# Typical clone-element runs take 2–4 turns; 12 is generous and cheap.
AGENT_MODEL_CALL_LIMIT=12
# Hard LangGraph ceiling. Only relevant for pathological loops the model-call
# limit above cannot detect (e.g. malformed tool output the model keeps
# re-parsing). Leave at 50 unless you have a specific reason.
AGENT_RECURSION_LIMIT=50

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of this backend (used in OAuth redirect URIs, session cookies)
BETTER_AUTH_URL=http://localhost:3001

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
